# ─── Variables de déploiement (lues par docker-compose) ──────────────
# Copier en « .env » à la racine du projet :  cp deploy.env.example .env
#
# Ce fichier ne contient QUE ce dont Caddy a besoin pour le HTTPS.
# La config applicative (Stripe, SMTP, CORS…) reste dans backend/.env.

# Domaine public du site (doit pointer vers ce serveur en DNS A/AAAA).
DOMAIN=voltpc.fr

# Email pour Let's Encrypt (notifications d'expiration de certificat).
ACME_EMAIL=admin@voltpc.fr
